# Origini consentite per il middleware CORS (separare con virgola)
# Esempio: http://localhost:5173,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173

# Livello di log: DEBUG (locale) | INFO | WARNING | ERROR (produzione)
LOG_LEVEL=DEBUG

# Numero di browser Chromium pre-avviati (ricerche simultanee supportate)
# Aumentare solo se il server ha abbastanza RAM (~300MB per browser)
BROWSER_POOL_SIZE=2
